{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "denali-shore-excursions",
  "compatibility_date": "2026-06-24",
  "observability": { "enabled": true },
  "assets": {
    "directory": ".",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "denalishoreexcursions.com",
      "custom_domain": true
    }
  ]
}
